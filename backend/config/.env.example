# LLM defaults
# Supported providers: zhipu, bailian, deepseek, openai
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5
LLM_API_KEY=
LLM_BASE_URL=

# Guardian (prompt-injection pre-filter)
# GUARDIAN_ENABLED=true -> enable pre-check; false -> bypass guardian
GUARDIAN_ENABLED=true
# Supported providers: zhipu, bailian, deepseek, openai
GUARDIAN_PROVIDER=openai
GUARDIAN_MODEL=gpt-4.1-mini
GUARDIAN_API_KEY=
GUARDIAN_BASE_URL=https://api.openai.com/v1
# Timeout for guardian request in milliseconds
GUARDIAN_TIMEOUT_MS=1500
# closed -> block when guardian call fails; open -> allow when guardian call fails
GUARDIAN_FAIL_MODE=closed
GUARDIAN_BLOCK_MESSAGE=检测到潜在不合规内容，本次请求已被拦截。

# Zhipu / BigModel
ZHIPU_API_KEY=your_key
ZHIPUAI_API_KEY=your_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5

# Bailian / DashScope
BAILIAN_API_KEY=your_key
DASHSCOPE_API_KEY=your_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible embeddings defaults
# Supported providers: bailian, openai
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# OpenAI embeddings
OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Tavily web search
TAVILY_API_KEY=your_key
TAVILY_PROJECT=

# Langfuse (tracing; optional)
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL=""

# Optional: Postgres checkpointer for production (short-term memory)
# CHECKPOINTER=postgres
# POSTGRES_DSN=postgresql://user:password@localhost:5432/dbname
# Or: POSTGRES_HOST, POSTGRES_PORT, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB

# Optional: Summarization (short-term memory compression)
# SUMMARIZATION_ENABLED=true
# SUMMARIZATION_TRIGGER_MESSAGES=50
# SUMMARIZATION_KEEP_MESSAGES=20

# Optional: Chroma for long-term memory vector store (default: backend/storage/chroma_memory)
# CHROMA_PERSIST_DIR=./storage/chroma_memory

# Optional: document-level RAG over backend/knowledge
# KNOWLEDGE_RAG_TOP_K=3
# KNOWLEDGE_RAG_CHUNK_SIZE=1200
# KNOWLEDGE_RAG_CHUNK_OVERLAP=200
# KNOWLEDGE_RAG_MAX_CHUNKS_PER_FILE=48
# KNOWLEDGE_RAG_DENSE_ENABLED=true

# ── Long-term memory backend (unified switch) ──
# "off" = no long-term memory (default)
# "v1"  = Chroma / MEMORY.md RAG (legacy)
# "v2"  = structured distillation + hybrid retrieval (recommended)
# MEMORY_BACKEND=off

# ── memory_module_v2: injection strategy (only when MEMORY_BACKEND=v2) ──
# "tool"   = register search_memory as agent tool, agent decides when to call (default)
# "always" = force-inject retrieval context every turn
# "off"    = v2 enabled for API use but no agent injection
# MEMORY_V2_INJECT=tool
# MEMORY_V2_INJECT_TOP_K=3

# ── memory_module_v2: dedicated distillation model (optional, saves tokens) ──
# Uses a smaller/cheaper model for session distillation.
# If not set, falls back to the main LLM (LLM_PROVIDER/LLM_MODEL).
# Supports the same providers as LLM_PROVIDER: zhipu, bailian, deepseek, openai
# Examples:
#   zhipu:    DISTILL_MODEL=glm-4-flash
#   bailian:  DISTILL_MODEL=qwen-turbo
#   deepseek: DISTILL_MODEL=deepseek-chat
# DISTILL_PROVIDER=
# DISTILL_MODEL=
# DISTILL_API_KEY=
# DISTILL_BASE_URL=

# ── memory_module_v2: BM25 keyword retrieval settings ──
# BM25_INDEX_DIR=./storage/memory_v2/bm25
# BM25_REBUILD_ON_START=false
# BM25_SHARDING=session
# BM25_MAX_DOCS=50000
# BM25_WINDOW_DAYS=30
# BM25_REBUILD_MIN_NEW_DOCS=500
# BM25_REBUILD_MIN_SECONDS=600
# BM25_USE_FACETS_IN_CORPUS=true

# Optional: tool permissions and audit logging
# TOOL_AUDIT_ENABLED=true
# TOOL_AUDIT_MAX_ENTRIES=500
# TERMINAL_TOOL_ENABLED=true
# PYTHON_REPL_TOOL_ENABLED=true
# FETCH_URL_TOOL_ENABLED=true
# READ_FILE_TOOL_ENABLED=true
# TERMINAL_ALLOWED_COMMANDS=Get-ChildItem,Get-Content,Select-String,python,pytest,uvicorn,npm,node,git
# READ_FILE_ALLOWED_PREFIXES=backend/,frontend/,docs/,skills/,workspace/,knowledge/
# READ_FILE_BLOCKED_PREFIXES=backend/config/.env,backend/storage/,frontend/node_modules/
# FETCH_URL_ALLOWED_HOSTS=docs.python.org,platform.openai.com
# FETCH_URL_BLOCKED_HOSTS=localhost,127.0.0.1
# FETCH_URL_ALLOW_PRIVATE_HOSTS=false
